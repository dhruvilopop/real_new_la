generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model DeletedUser {
  id           String   @id @default(cuid())
  email        String   @unique
  firebaseUid  String?  @unique
  originalRole String
  deletedById  String?
  deletedAt    DateTime @default(now())
  reason       String?
  @@index([email])
  @@index([firebaseUid])
}

model User {
  id                     String              @id @default(cuid())
  firebaseUid            String              @unique
  email                  String              @unique
  phone                  String?
  name                   String?
  role                   UserRole            @default(CUSTOMER)
  isActive               Boolean             @default(true)
  isLocked               Boolean             @default(false)
  failedLoginAttempts    Int                 @default(0)
  lastLoginAt            DateTime?
  profilePicture         String?
  companyId              String?
  agentId                String?
  agentCode              String?             @unique
  commissionRate         Float?              @default(0)
  staffCode              String?             @unique
  assignedBranch         String?
  cashierCode            String?             @unique
  accountantCode         String?             @unique
  dailyLimit             Float?              @default(100000)
  panNumber              String?
  aadhaarNumber          String?
  dateOfBirth            DateTime?
  address                String?
  city                   String?
  state                  String?
  pincode                String?
  employmentType         String?
  monthlyIncome          Float?
  bankAccountNumber      String?
  bankIfsc               String?
  bankName               String?
  termsAccepted          Boolean             @default(false)
  termsAcceptedAt        DateTime?
  termsAcceptedIp        String?
  privacyAccepted        Boolean             @default(false)
  privacyAcceptedAt      DateTime?
  privacyAcceptedIp      String?
  password               String?
  verificationCode       String?
  verificationCodeExpiry DateTime?
  staffVerificationCode  String?
  showPassword           Boolean             @default(false)
  plainPassword          String?
  loginType              String              @default("EMAIL")
  lastActivityAt         DateTime?
  lastLocation           String?
  // Credit System Fields - Dual Credit System
  companyCredit          Float               @default(0) // Company credit - only CASH payments increase this
  personalCredit         Float               @default(0) // Personal credit - when money taken in personal account
  // Legacy field for backward compatibility
  credit                 Float               @default(0) // Total credit (companyCredit + personalCredit)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  deletedAt              DateTime?
  auditLogs              AuditLog[]
  blacklists             Blacklist[]
  deviceFingerprints     DeviceFingerprint[]
  disbursedLoans         LoanApplication[]   @relation("DisbursedBy")
  rejectedLoans          LoanApplication[]   @relation("RejectedBy")
  processedLoans         LoanApplication[]   @relation("ProcessedLoans")
  loanApplications       LoanApplication[]   @relation("CustomerApplications")
  locationLogs           LocationLog[]
  notifications          Notification[]
  cashierPayments        Payment[]           @relation("CashierPayments")
  payments               Payment[]           @relation("CustomerPayments")
  reminders              Reminder[]
  sessions               SessionForm[]
  notificationSettings   NotificationSetting[]
  agent                  User?               @relation("AgentStaff", fields: [agentId], references: [id])
  staffMembers           User[]              @relation("AgentStaff")
  company                Company?            @relation(fields: [companyId], references: [id])
  workflowLogs           WorkflowLog[]
  // Credit System Relations
  creditTransactions     CreditTransaction[] @relation("UserCreditTransactions")
  creditSettlements      CashierSettlement[] @relation("UserSettlements")
  receivedSettlements    CashierSettlement[] @relation("CashierReceivedSettlements")
  // Advanced features relations
  preApprovedOffers      PreApprovedOffer[]
  creditRiskScores       CreditRiskScore[]
  referrals              Referral[]
  agentPerformance       AgentPerformance[]
  // Offline Loan relations
  createdOfflineLoans    OfflineLoan[]      @relation("OfflineLoanCreator")
  offlineLoansAsCustomer OfflineLoan[]      @relation("OfflineLoanCustomer")
  collectedEMIs          OfflineLoanEMI[]
  emiReminders           EMIReminderLog[]
  // Action Log relations
  actionLogs             ActionLog[]
  undoneActions          ActionLog[]        @relation("ActionUndoBy")
  redoneActions          ActionLog[]        @relation("ActionRedoBy")
  // Payment Request relations
  paymentRequests        PaymentRequest[]
  reviewedPaymentRequests PaymentRequest[]  @relation("PaymentRequestReviewer")
  // Secondary Payment Pages (created by this user)
  createdSecondaryPaymentPages SecondaryPaymentPage[]
  // EMI Payment Settings modifications
  modifiedEMIPaymentSettings EMIPaymentSetting[]
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([agentId])
}

model Company {
  id                  String            @id @default(cuid())
  name                String
  code                String            @unique
  registrationNo      String?
  gstNumber           String?
  address             String?
  city                String?
  state               String?
  pincode             String?
  contactEmail        String?
  contactPhone        String?
  isActive            Boolean           @default(true)
  maxLoanAmount       Float             @default(10000000)
  minLoanAmount       Float             @default(10000)
  defaultInterestRate Float             @default(12)
  maxTenureMonths     Int               @default(60)
  // Company Credit - only CASH payments increase this
  companyCredit       Float             @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?
  // Relations
  ledgers             Ledger[]
  loanApplications    LoanApplication[]
  users               User[]
  // Accounting Relations
  chartOfAccounts     ChartOfAccount[]
  financialYears      FinancialYear[]
  journalEntries      JournalEntry[]
  expenses            Expense[]
  bankAccounts        BankAccount[]
  gstConfigs          GSTConfig[]
  // Advanced features relations
  preApprovedOffers   PreApprovedOffer[]
  commissionSlabs     CommissionSlab[]
  gracePeriodConfigs  GracePeriodConfig[]
  agentPerformance    AgentPerformance[]
  // Offline Loan relations
  offlineLoans        OfflineLoan[]
  // Fixed Assets relations
  fixedAssets         FixedAsset[]
  // Payment Settings
  paymentSettings     CompanyPaymentSettings?
  // Secondary Payment Pages (for display only)
  secondaryPaymentPages SecondaryPaymentPage[]
  @@index([code])
}

model LoanApplication {
  id                    String        @id @default(cuid())
  applicationNo         String        @unique
  customerId            String
  companyId             String?
  loanType              LoanType      @default(PERSONAL)
  status                LoanStatus    @default(SUBMITTED)
  requestedAmount       Float
  requestedTenure       Int
  requestedInterestRate Float?
  purpose               String?
  title                 String?
  firstName             String?
  middleName            String?
  lastName              String?
  fatherName            String?
  motherName            String?
  gender                String?
  maritalStatus         String?
  panNumber             String?
  aadhaarNumber         String?
  dateOfBirth           DateTime?
  nationality           String?
  address               String?
  city                  String?
  state                 String?
  pincode               String?
  phone                 String?
  employmentType        String?
  employerName          String?
  employerAddress       String?
  designation           String?
  yearsInEmployment     Int?
  totalWorkExperience   Int?
  officePhone           String?
  officeEmail           String?
  monthlyIncome         Float?
  annualIncome          Float?
  otherIncome           Float?
  incomeSource          String?
  // Employment-specific fields
  businessName          String?
  businessType          String?
  yearsInBusiness       Int?
  annualTurnover        Float?
  businessAddress       String?
  companyType           String?
  yearsInOperation      Int?
  annualRevenue         Float?
  numberOfEmployees     Int?
  professionType        String?
  practiceName          String?
  yearsOfPractice       Int?
  professionalRegNo     String?
  previousEmployer      String?
  retirementDate        DateTime?
  pensionAmount         Float?
  spouseName            String?
  spouseOccupation      String?
  spouseIncome          Float?
  familyIncome          Float?
  institutionName       String?
  courseProgram         String?
  expectedCompletion    DateTime?
  guardianName          String?
  guardianIncome        Float?
  sourceOfFunds         String?
  monthlySupportAmount  Float?
  supportProviderName   String?
  // Bank Details
  bankAccountNumber     String?
  bankIfsc              String?
  bankName              String?
  bankBranch            String?
  accountType           String?
  accountHolderName     String?
  loanAmount            Float?
  tenure                Int?
  interestRate          Float?
  emiAmount             Float?
  processingFee         Float?
  panCardDoc            String?
  aadhaarFrontDoc       String?
  aadhaarBackDoc        String?
  incomeProofDoc        String?
  addressProofDoc       String?
  photoDoc              String?
  bankStatementDoc      String?
  salarySlipDoc         String?
  electionCardDoc       String?
  housePhotoDoc         String?
  otherDocs             String?
  reference1Name        String?
  reference1Phone       String?
  reference1Relation    String?
  reference1Address     String?
  reference2Name        String?
  reference2Phone       String?
  reference2Relation    String?
  reference2Address     String?
  digitalSignature      String?
  signatureHash         String?
  consentGiven          Boolean       @default(false)
  consentTimestamp      DateTime?
  consentIp             String?
  applicationLocation   String?
  currentHandlerId      String?
  currentStage          String?
  riskScore             Int?          @default(0)
  fraudFlag             Boolean       @default(false)
  fraudReason           String?
  rejectionReason       String?
  rejectedById          String?
  rejectedAt            DateTime?
  disbursedAmount       Float?
  disbursedAt           DateTime?
  disbursedById         String?
  disbursementMode      String?
  disbursementRef       String?
  disbursementProof     String?
  submittedAt           DateTime      @default(now())
  saApprovedAt          DateTime?
  companyApprovedAt     DateTime?
  agentApprovedAt       DateTime?
  loanFormCompletedAt   DateTime?
  sessionCreatedAt      DateTime?
  customerApprovedAt    DateTime?
  finalApprovedAt       DateTime?
  closedAt              DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  deletedAt             DateTime?
  auditLogs             AuditLog[]
  emiSchedules          EMISchedule[]
  disbursedBy           User?         @relation("DisbursedBy", fields: [disbursedById], references: [id])
  rejectedBy            User?         @relation("RejectedBy", fields: [rejectedById], references: [id])
  processedBy           User?         @relation("ProcessedLoans", fields: [currentHandlerId], references: [id])
  company               Company?      @relation(fields: [companyId], references: [id])
  customer              User          @relation("CustomerApplications", fields: [customerId], references: [id])
  loanForm              LoanForm?
  payments              Payment[]
  sessionForm           SessionForm?
  workflowLogs          WorkflowLog[]
  // Advanced features relations
  loanTopUps            LoanTopUp[]
  foreclosureRequests   ForeclosureRequest[]
  emiDateChangeRequests EMIDateChangeRequest[]
  counterOffers         CounterOffer[]
  documentRequests      DocumentRequest[]
  loanRestructures      LoanRestructure[]
  npaTrackings          NPATracking[]
  fraudAlerts           FraudAlert[]
  appointments          Appointment[]
  loanAgreement         LoanAgreement?
  progressTimelines     LoanProgressTimeline[]
  applicationFingerprints ApplicationFingerprint[]
  // Payment Request relations
  paymentRequests        PaymentRequest[]
  // EMI Payment Settings
  emiPaymentSettings    EMIPaymentSetting[]
  @@index([applicationNo])
  @@index([customerId])
  @@index([status])
  @@index([companyId])
}

model LoanForm {
  id                  String          @id @default(cuid())
  loanApplicationId   String          @unique
  panVerified         Boolean         @default(false)
  aadhaarVerified     Boolean         @default(false)
  bankVerified        Boolean         @default(false)
  employmentVerified  Boolean         @default(false)
  addressVerified     Boolean         @default(false)
  incomeVerified      Boolean         @default(false)
  verificationRemarks String?
  verificationDate    DateTime?
  verifiedById        String?
  riskScore           Int             @default(0)
  riskFactors         String?
  fraudFlag           Boolean         @default(false)
  fraudReason         String?
  internalRemarks     String?
  visitDate           DateTime?
  visitAddress        String?
  visitRemarks        String?
  visitLatitude       Float?
  visitLongitude      Float?
  visitPhotos         String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?
  loanApplication     LoanApplication @relation(fields: [loanApplicationId], references: [id])
  @@index([loanApplicationId])
}

model SessionForm {
  id                    String          @id @default(cuid())
  loanApplicationId     String          @unique
  agentId               String
  approvedAmount        Float
  interestRate          Float
  tenure                Int
  emiFrequency          String          @default("MONTHLY")
  processingFee         Float           @default(0)
  processingFeeType     String          @default("PERCENTAGE")
  emiAmount             Float
  totalInterest         Float
  totalAmount           Float
  moratoriumPeriod      Int             @default(0)
  moratoriumType        String?
  latePaymentPenalty    Float           @default(0)
  bounceCharges         Float           @default(0)
  specialConditions     String?
  requestedAmount       Float?
  requestedTenure       Int?
  requestedInterestRate Float?
  customerApproved      Boolean         @default(false)
  customerApprovedAt    DateTime?
  customerSignature     String?
  customerSignatureHash String?
  rejected              Boolean         @default(false)
  rejectedAt            DateTime?
  rejectionReason       String?
  isLocked              Boolean         @default(false)
  lockedAt              DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?
  agent                 User            @relation(fields: [agentId], references: [id])
  loanApplication       LoanApplication @relation(fields: [loanApplicationId], references: [id])
  @@index([loanApplicationId])
  @@index([agentId])
}

model EMISchedule {
  id                   String           @id @default(cuid())
  loanApplicationId    String
  installmentNumber    Int
  dueDate              DateTime
  originalDueDate      DateTime
  principalAmount      Float
  interestAmount       Float
  totalAmount          Float
  outstandingPrincipal Float
  outstandingInterest  Float
  paidAmount           Float            @default(0)
  paidPrincipal        Float            @default(0)
  paidInterest         Float            @default(0)
  paymentStatus        EMIPaymentStatus @default(PENDING)
  paidDate             DateTime?
  paymentMode          String?
  paymentReference     String?
  utrNumber            String?
  proofUrl             String?           // Payment proof document URL
  notes                String?           // Payment notes
  isPartialPayment     Boolean          @default(false)
  nextPaymentDate      DateTime?
  isInterestOnly       Boolean          @default(false)
  principalDeferred    Boolean          @default(false)
  penaltyAmount        Float            @default(0)
  penaltyPaid          Float            @default(0)
  waivedAmount         Float            @default(0)
  waiverReason         String?
  waivedById           String?
  waivedAt             DateTime?
  daysOverdue          Int              @default(0)
  overdueNoticeSent    Boolean          @default(false)
  lastNoticeDate       DateTime?
  // Partial Payment Tracking
  partialPaymentCount  Int              @default(0)  // Number of partial payments made (max 2)
  remainingAmount      Float            @default(0)  // Amount remaining after partial payment
  newDueDate           DateTime?        // New due date after partial payment
  // Interest Only Payment Tracking
  interestOnlyPaidAt   DateTime?        // When interest only was paid
  interestOnlyAmount   Float            @default(0)  // Interest amount paid
  duplicatedEMINumber  Int?             // If this EMI was duplicated due to interest only payment
  originalEMIId        String?          // Reference to original EMI if this is a duplicate
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  loanApplication      LoanApplication  @relation(fields: [loanApplicationId], references: [id])
  payments             Payment[]
  paymentRequests      PaymentRequest[]
  paymentSetting       EMIPaymentSetting?
  @@unique([loanApplicationId, installmentNumber])
  @@index([loanApplicationId])
  @@index([dueDate])
  @@index([paymentStatus])
}

model Payment {
  id                 String          @id @default(cuid())
  loanApplicationId  String
  emiScheduleId      String?
  customerId         String
  cashierId          String?
  paidById           String?         // Who made the payment (staff/cashier/agent)
  paymentType        PaymentType     @default(FULL_EMI)
  amount             Float
  principalComponent Float           @default(0)
  interestComponent  Float           @default(0)
  penaltyComponent   Float           @default(0)
  transactionId      String?         @unique
  utrNumber          String?
  paymentMode        String?
  paymentGateway     String?
  gatewayResponse    String?
  status             PaymentStatus   @default(PENDING)
  verified           Boolean         @default(false)
  verifiedById       String?
  verifiedAt         DateTime?
  receiptNumber      String?         @unique
  receiptGenerated   Boolean         @default(false)
  receiptSentAt      DateTime?
  paymentLocation    String?
  deviceInfo         String?
  reconciled         Boolean         @default(false)
  reconciledAt       DateTime?
  reconciliationRef  String?
  proofUrl           String?         // Payment proof document
  remarks            String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?
  auditLogs          AuditLog[]
  cashier            User?           @relation("CashierPayments", fields: [cashierId], references: [id])
  customer           User            @relation("CustomerPayments", fields: [customerId], references: [id])
  emiSchedule        EMISchedule?    @relation(fields: [emiScheduleId], references: [id])
  loanApplication    LoanApplication @relation(fields: [loanApplicationId], references: [id])
  @@index([loanApplicationId])
  @@index([customerId])
  @@index([status])
  @@index([transactionId])
}

model WorkflowLog {
  id                String          @id @default(cuid())
  loanApplicationId String
  actionById        String
  previousStatus    String?
  newStatus         String
  action            String
  remarks           String?
  ipAddress         String?
  userAgent         String?
  location          String?
  signatureHash     String?
  createdAt         DateTime        @default(now())
  actionBy          User            @relation(fields: [actionById], references: [id])
  loanApplication   LoanApplication @relation(fields: [loanApplicationId], references: [id])
  @@index([loanApplicationId])
  @@index([actionById])
}

model AuditLog {
  id                String           @id @default(cuid())
  userId            String
  loanApplicationId String?
  paymentId         String?
  action            String
  module            String
  description       String
  oldValue          String?
  newValue          String?
  ipAddress         String?
  userAgent         String?
  location          String?
  recordId          String?
  recordType        String?
  createdAt         DateTime         @default(now())
  payment           Payment?         @relation(fields: [paymentId], references: [id])
  loanApplication   LoanApplication? @relation(fields: [loanApplicationId], references: [id])
  user              User             @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
}

model LocationLog {
  id                String   @id @default(cuid())
  userId            String
  latitude          Float
  longitude         Float
  accuracy          Float?
  action            String
  loanApplicationId String?
  paymentId         String?
  deviceId          String?
  deviceType        String?
  browser           String?
  os                String?
  ipAddress         String?
  address           String?
  city              String?
  state             String?
  country           String?
  pincode           String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model NotificationSetting {
  id                           String   @id @default(cuid())
  userId                       String
  enableEMIReminders           Boolean  @default(true)
  reminderDaysBeforeDue        Int      @default(3)
  enableOverdueAlerts          Boolean  @default(true)
  enablePaymentConfirmation    Boolean  @default(true)
  enableLoanStatusUpdates      Boolean  @default(true)
  preferredChannel             String   @default("IN_APP")
  reminderTime                 String   @default("09:00")
  enableSMS                    Boolean  @default(false)
  enableEmail                  Boolean  @default(false)
  enablePush                   Boolean  @default(true)
  customReminderMessage        String?
  overdueReminderMessage       String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  user                         User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  data      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([isRead])
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  scheduledAt DateTime
  sentAt    DateTime?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([scheduledAt])
}

model Blacklist {
  id        String   @id @default(cuid())
  userId    String
  reason    String
  blacklistedAt DateTime @default(now())
  blacklistedBy String?
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
}

model DeviceFingerprint {
  id        String   @id @default(cuid())
  userId    String
  deviceId  String
  deviceName String?
  lastUsed  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([deviceId])
}

model Ledger {
  id          String   @id @default(cuid())
  companyId   String
  type        String
  amount      Float
  description String?
  reference   String?
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id])
  @@index([companyId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CMSService {
  id                  String   @id @default(cuid())
  title               String
  description         String
  icon                String?
  loanType            String   @default("PERSONAL")
  minInterestRate     Float    @default(8)
  maxInterestRate     Float    @default(24)
  defaultInterestRate Float    @default(12)
  minTenure           Int      @default(6)
  maxTenure           Int      @default(60)
  defaultTenure       Int      @default(12)
  minAmount           Float    @default(10000)
  maxAmount           Float    @default(10000000)
  processingFeePercent Float   @default(1)
  processingFeeMin    Float    @default(500)
  processingFeeMax    Float    @default(10000)
  latePaymentPenaltyPercent Float @default(2)
  latePaymentPenalty  Float    @default(500) // Fixed amount in rupees per late EMI
  gracePeriodDays     Int      @default(5)
  bounceCharges       Float    @default(500)
  allowMoratorium     Boolean  @default(true)
  maxMoratoriumMonths Int      @default(3)
  allowPrepayment     Boolean  @default(true)
  prepaymentCharges   Float    @default(2)
  isActive            Boolean  @default(true)
  order               Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CMSBanner {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?
  imageUrl    String?
  linkUrl     String?
  buttonText  String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CMSTestimonial {
  id            String   @id @default(cuid())
  customerName  String
  designation   String?
  content       String
  rating        Int      @default(5)
  imageUrl      String?
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FormConfig {
  id          String   @id @default(cuid())
  formType    String   @unique
  fields      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UploadedFile {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  uploadedBy  String?
  createdAt   DateTime @default(now())
  @@index([uploadedBy])
}

// ==================== ACCOUNTING MODULE ====================

// Chart of Accounts - Master ledger accounts
model ChartOfAccount {
  id              String           @id @default(cuid())
  companyId       String           @default("default") // Company this account belongs to
  accountCode     String           
  accountName     String
  accountType     AccountType
  parentAccountId String?
  parentAccount   ChartOfAccount?  @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  subAccounts     ChartOfAccount[] @relation("AccountHierarchy")
  description     String?
  isSystemAccount Boolean          @default(false)
  isActive        Boolean          @default(true)
  openingBalance  Float            @default(0)
  currentBalance  Float            @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  journalLines    JournalEntryLine[]
  ledgerBalances  LedgerBalance[]
  company         Company?         @relation(fields: [companyId], references: [id])
  @@unique([companyId, accountCode])
  @@index([companyId])
  @@index([accountCode])
  @@index([accountType])
  @@index([isActive])
}

// Financial Years
model FinancialYear {
  id               String         @id @default(cuid())
  companyId        String         @default("default") // Company this financial year belongs to
  name             String         
  startDate        DateTime
  endDate          DateTime
  isClosed         Boolean        @default(false)
  closedAt         DateTime?
  closedById       String?
  previousYearId   String?
  carryForwardDone Boolean       @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  ledgerBalances   LedgerBalance[]
  company          Company?       @relation(fields: [companyId], references: [id])
  @@unique([companyId, name])
  @@index([companyId])
  @@index([startDate])
  @@index([endDate])
  @@index([isClosed])
}

// Ledger Balances - Year-wise account balances
model LedgerBalance {
  id               String          @id @default(cuid())
  accountId        String
  financialYearId  String
  openingBalance   Float           @default(0)
  totalDebits      Float           @default(0)
  totalCredits     Float           @default(0)
  closingBalance   Float           @default(0)
  account          ChartOfAccount  @relation(fields: [accountId], references: [id])
  financialYear    FinancialYear   @relation(fields: [financialYearId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  @@unique([accountId, financialYearId])
  @@index([accountId])
  @@index([financialYearId])
}

// Journal Entries - Main entry header
model JournalEntry {
  id                String              @id @default(cuid())
  companyId         String              @default("default") // Company this journal entry belongs to
  entryNumber       String              
  entryDate         DateTime
  referenceType     String?             // LOAN_DISBURSEMENT, EMI_PAYMENT, FEE_COLLECTION, MANUAL, etc.
  referenceId       String?             // Loan ID, Payment ID, etc.
  narration         String?
  totalDebit        Float               @default(0)
  totalCredit       Float               @default(0)
  isAutoEntry       Boolean             @default(false)
  isReversed        Boolean             @default(false)
  reversedById      String?
  reversedAt        DateTime?
  isApproved        Boolean             @default(false)
  approvedById      String?
  approvedAt        DateTime?
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  // Payment details for tracking
  paymentMode       String?             // CASH, BANK_TRANSFER, CHEQUE, UPI, etc.
  chequeNumber      String?
  chequeDate        DateTime?
  bankRefNumber     String?
  bankAccountId     String?
  lines             JournalEntryLine[]
  company           Company?            @relation(fields: [companyId], references: [id])
  @@unique([companyId, entryNumber])
  @@index([companyId])
  @@index([entryNumber])
  @@index([entryDate])
  @@index([referenceType])
  @@index([referenceId])
  @@index([isAutoEntry])
  @@index([isApproved])
  @@index([paymentMode])
  @@index([bankAccountId])
}

// Journal Entry Lines - Individual debit/credit lines
model JournalEntryLine {
  id              String        @id @default(cuid())
  journalEntryId  String
  accountId       String
  debitAmount     Float         @default(0)
  creditAmount    Float         @default(0)
  narration       String?
  loanId          String?
  customerId      String?
  runningBalance  Float?        @default(0)
  balanceType     String?       // DEBIT or CREDIT
  createdAt       DateTime      @default(now())
  account         ChartOfAccount @relation(fields: [accountId], references: [id])
  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  @@index([journalEntryId])
  @@index([accountId])
  @@index([loanId])
  @@index([customerId])
}

// Reports Cache - Store generated reports
model ReportsCache {
  id              String   @id @default(cuid())
  reportType      String
  reportName      String
  parameters      String   // JSON string of parameters
  generatedAt     DateTime @default(now())
  data            String   // JSON string of report data
  generatedById   String
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  @@index([reportType])
  @@index([generatedAt])
  @@index([generatedById])
}

// Expense Management
model Expense {
  id              String       @id @default(cuid())
  companyId       String       @default("default") // Company this expense belongs to
  expenseNumber   String
  expenseType     String       // SALARY, RENT, MARKETING, COMMISSION, etc.
  description     String
  amount          Float
  paymentDate     DateTime
  paymentMode     String       // CASH, BANK_TRANSFER, CHEQUE, etc.
  paymentReference String?
  payeeName       String?
  payeeId         String?
  categoryId      String?
  isApproved      Boolean      @default(false)
  approvedById    String?
  approvedAt      DateTime?
  createdById     String
  receiptUrl      String?
  remarks         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  company         Company?     @relation(fields: [companyId], references: [id])
  @@unique([companyId, expenseNumber])
  @@index([companyId])
  @@index([expenseNumber])
  @@index([expenseType])
  @@index([paymentDate])
  @@index([isApproved])
}

// Bank Transaction Log - Tracks all bank movements
model BankTransaction {
  id              String   @id @default(cuid())
  bankAccountId   String
  transactionType String   // CREDIT (money in) or DEBIT (money out)
  amount          Float
  balanceAfter    Float    // Balance after this transaction
  description     String
  referenceType   String   // LOAN_DISBURSEMENT, EMI_PAYMENT, EXPENSE, etc.
  referenceId     String?  // ID of the related record
  createdById     String
  transactionDate DateTime @default(now())
  createdAt       DateTime @default(now())
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([referenceType])
}

// GST Configuration
model GSTConfig {
  id              String   @id @default(cuid())
  companyId       String   @default("default") // Company this GST config belongs to
  gstRate         Float
  gstType         String   // CGST, SGST, IGST
  applicableFrom  DateTime
  applicableTo    DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company? @relation(fields: [companyId], references: [id])
  @@unique([companyId, gstType, applicableFrom])
  @@index([companyId])
  @@index([gstType])
  @@index([isActive])
}

// Bank Accounts
model BankAccount {
  id              String   @id @default(cuid())
  companyId       String   @default("default") // Company this bank account belongs to
  bankName        String
  accountNumber   String
  accountName     String
  branchName      String?
  ifscCode        String?
  accountType     String   // SAVINGS, CURRENT, etc.
