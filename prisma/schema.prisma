// ==================== CREDIT & COLLECTION SYSTEM ====================

// Credit Transaction - Track all credit movements (EMI payments by roles)
model CreditTransaction {
  id                  String              @id @default(cuid())
  userId              String              // User whose credit is affected
  transactionType     CreditTransactionType // CREDIT_INCREASE, CREDIT_DECREASE, SETTLEMENT, PERSONAL_CLEARANCE
  amount              Float               // Amount involved
  paymentMode         PaymentModeType     // CASH, CHEQUE, ONLINE, UPI, BANK_TRANSFER
  
  // Dual Credit System
  creditType          CreditType          @default(COMPANY) // COMPANY or PERSONAL
  companyBalanceAfter Float?              // Company credit balance after this transaction
  personalBalanceAfter Float?             // Personal credit balance after this transaction
  balanceAfter        Float               // Total credit balance after this transaction (legacy)
  
  // Reference to what caused this transaction
  sourceType          String              // EMI_PAYMENT, SETTLEMENT, ADJUSTMENT, PERSONAL_COLLECTION
  sourceId            String?             // Payment ID, Settlement ID, etc.
  
  // EMI Payment Details (when source is EMI_PAYMENT)
  loanApplicationId   String?
  emiScheduleId       String?
  customerId          String?
  installmentNumber   Int?
  
  // Customer Details (for quick reference without joins)
  customerName        String?
  customerPhone       String?
  loanApplicationNo   String?
  
  // EMI Details (for quick reference)
  emiDueDate          DateTime?
  emiAmount           Float?
  principalComponent  Float?
  interestComponent   Float?
  
  // Additional details
  chequeNumber        String?
  chequeDate          DateTime?
  bankRefNumber       String?
  utrNumber           String?
  description         String?
  remarks             String?
  
  // Proof Document (required for CHEQUE, ONLINE, and PERSONAL transactions)
  proofDocument       String?             // File path to uploaded proof
  proofType           String?             // Type of proof (image, pdf, etc.)
  proofUploadedAt     DateTime?
  proofVerified       Boolean             @default(false)
  proofVerifiedBy     String?
  proofVerifiedAt     DateTime?
  
  // For settlements
  settlementId        String?             // Reference to CashierSettlement
  
  // Collection Details
  collectedFrom       String?             // Name of person who paid
  collectedFromPhone  String?             // Phone of person who paid
  collectionLocation  String?             // Location where payment was collected
  collectionLatitude  Float?
  collectionLongitude Float?
  
  // Timestamps
  transactionDate     DateTime            @default(now()) // When the actual transaction happened
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relations
  user                User                @relation("UserCreditTransactions", fields: [userId], references: [id])
  settlement          CashierSettlement?  @relation(fields: [settlementId], references: [id])
  
  @@index([userId])
  @@index([transactionType])
  @@index([paymentMode])
  @@index([creditType])
  @@index([sourceType])
  @@index([loanApplicationId])
  @@index([customerId])
  @@index([createdAt])
  @@index([transactionDate])
}

// Cashier Settlement - When role gives money to cashier
model CashierSettlement {
  id                  String              @id @default(cuid())
  settlementNumber    String              @unique
  userId              String              // User giving the money
  cashierId           String              // Cashier receiving the money
  amount              Float               // Total amount settled
  paymentMode         PaymentModeType     // CASH, CHEQUE, ONLINE
  // Payment details
  chequeNumber        String?
  chequeDate          DateTime?
  bankRefNumber       String?
  utrNumber           String?
  // Status
  status              SettlementStatus    @default(PENDING) // PENDING, VERIFIED, COMPLETED
  verifiedById        String?             // Accountant who verified
  verifiedAt          DateTime?
  // Denomination breakdown for cash
  cashDenominations   String?             // JSON string with denomination breakdown
  // Remarks
  remarks             String?
  rejectionReason     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  user                User                @relation("UserSettlements", fields: [userId], references: [id])
  cashier             User                @relation("CashierReceivedSettlements", fields: [cashierId], references: [id])
  creditTransactions  CreditTransaction[]
  @@index([userId])
  @@index([cashierId])
  @@index([status])
  @@index([paymentMode])
  @@index([createdAt])
}

// Daily Collection Summary - Aggregated daily collection data
model DailyCollection {
  id                  String              @id @default(cuid())
  date                DateTime            @default(now())
  // Collection by mode
  totalCash           Float               @default(0)
  totalCheque         Float               @default(0)
  totalOnline         Float               @default(0)
  totalAmount         Float               @default(0)
  // Counts
  totalTransactions   Int                 @default(0)
  emiPaymentsCount    Int                 @default(0)
  settlementsCount    Int                 @default(0)
  // Breakdown by role
  superAdminCollection Float              @default(0)
  companyCollection   Float               @default(0)
  agentCollection     Float               @default(0)
  staffCollection     Float               @default(0)
  cashierCollection   Float               @default(0)
  customerDirect      Float               @default(0)
  // Metadata
  companyId           String?
  branchId            String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  @@unique([date])
  @@index([date])
  @@index([companyId])
}

// Credit Transaction Types Enum
enum CreditTransactionType {
  CREDIT_INCREASE     // When role collects EMI payment
  CREDIT_DECREASE     // When role settles with cashier/superadmin
  SETTLEMENT          // When cashier receives payment
  ADJUSTMENT          // Manual adjustment by admin
  PERSONAL_CLEARANCE  // When personal credit is cleared by superadmin
  PERSONAL_COLLECTION // When money collected in personal account
}

// Credit Type Enum - Dual Credit System
enum CreditType {
  COMPANY             // Company credit - only CASH increases this
  PERSONAL            // Personal credit - requires proof for all transactions
}

// Payment Mode Enum
enum PaymentModeType {
  CASH                // Only CASH increases company credit
  CHEQUE              // Requires proof, doesn't increase company credit
  ONLINE              // Requires proof, doesn't increase company credit
  UPI                 // Requires proof, doesn't increase company credit
  BANK_TRANSFER       // Requires proof, doesn't increase company credit
  SYSTEM              // For system-generated transactions (deductions, transfers, etc.)
}

// Settlement Status Enum
enum SettlementStatus {
  PENDING
  VERIFIED
  COMPLETED
  REJECTED
}

// ==================== OFFLINE LOAN SYSTEM ====================

// Offline Loan - Created by SuperAdmin or Agent directly
model OfflineLoan {
  id                    String              @id @default(cuid())
  loanNumber            String              @unique
  // Creator info
  createdById           String              // Who created this loan (SuperAdmin or Agent)
  createdByRole         String              // SUPER_ADMIN, AGENT
  companyId             String?
  // Customer info (can be new or existing)
  customerId            String?             // Link to existing user if available
  customerName          String
  customerPhone         String
  customerEmail         String?
  customerAadhaar       String?
  customerPan           String?
  customerAddress       String?
  customerCity          String?
  customerState         String?
  customerPincode       String?
  customerDOB           DateTime?
  customerOccupation    String?
  customerMonthlyIncome Float?
  // Reference contacts
  reference1Name        String?
  reference1Phone       String?
  reference1Relation    String?
  reference2Name        String?
  reference2Phone       String?
  reference2Relation    String?
  // Loan details
  loanType              LoanType            @default(PERSONAL)
  loanAmount            Float
  interestRate          Float
  tenure                Int                 // in months
  emiAmount             Float
  processingFee         Float               @default(0)
  disbursementDate      DateTime
  disbursementMode      String?             // CASH, BANK_TRANSFER, CHEQUE
  disbursementRef       String?             // Transaction reference
  // Status
  status                OfflineLoanStatus   @default(ACTIVE)
  // Payment options control
  allowInterestOnly     Boolean             @default(true)    // Allow interest-only payments
  allowPartialPayment   Boolean             @default(true)    // Allow partial payments
  // Dates
  startDate             DateTime            // EMI start date
  closedAt              DateTime?
  // Notes
  notes                 String?
  internalNotes         String?
  // Timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  // Relations
  emis                  OfflineLoanEMI[]
  createdBy             User                @relation("OfflineLoanCreator", fields: [createdById], references: [id])
  company               Company?            @relation(fields: [companyId], references: [id])
  customer              User?               @relation("OfflineLoanCustomer", fields: [customerId], references: [id])
  @@index([loanNumber])
  @@index([createdById])
  @@index([customerId])
  @@index([status])
  @@index([disbursementDate])
}

// Offline Loan EMI Schedule
model OfflineLoanEMI {
  id                    String              @id @default(cuid())
  offlineLoanId         String
  installmentNumber     Int
  dueDate               DateTime
  principalAmount       Float
  interestAmount        Float
  totalAmount           Float
  outstandingPrincipal  Float
  // Payment tracking
  paidAmount            Float               @default(0)
  paidPrincipal         Float               @default(0)
  paidInterest          Float               @default(0)
  paymentStatus         EMIPaymentStatus    @default(PENDING)
  paidDate              DateTime?
  paymentMode           String?
  paymentReference      String?
  // Penalty
  penaltyAmount         Float               @default(0)
  penaltyPaid           Float               @default(0)
  daysOverdue           Int                 @default(0)
  // Collection tracking
  collectedById         String?             // Who collected the payment
  collectedByName       String?             // Name of collector
  collectedAt           DateTime?
  // Reminder tracking
  reminderSent          Boolean             @default(false)
  reminderSentAt        DateTime?
  // Deferred EMI tracking (for interest-only payments)
  isDeferred            Boolean             @default(false)    // True if this EMI was deferred due to interest-only payment
  deferredFromEMI       Int?                                   // Original EMI number this was deferred from
  // Timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  // Relations
  offlineLoan           OfflineLoan         @relation(fields: [offlineLoanId], references: [id], onDelete: Cascade)
  collector             User?               @relation(fields: [collectedById], references: [id])
  @@unique([offlineLoanId, installmentNumber])
  @@index([offlineLoanId])
  @@index([dueDate])
  @@index([paymentStatus])
  @@index([collectedById])
}

// EMI Reminder Log - Track all reminders sent
model EMIReminderLog {
  id                    String              @id @default(cuid())
  // EMI reference (can be online or offline)
  emiScheduleId         String?             // For online loans
  offlineLoanEMIId      String?             // For offline loans
  // Recipient info
  userId                String              // Who received the reminder
  userRole              String              // Role of the recipient
  // Reminder details
  reminderType          String              // EMI_DUE_TODAY, EMI_DUE_TOMORROW, EMI_OVERDUE, etc.
  loanId                String              // Loan reference
  loanNumber            String              // Loan number for display
  customerName          String              // Customer name
  emiAmount             Float               // EMI amount
  dueDate               DateTime            // EMI due date
  // Status
  sentAt                DateTime            @default(now())
  sentVia               String              // IN_APP, SMS, EMAIL
  isRead                Boolean             @default(false)
  readAt                DateTime?
  // Timestamps
  createdAt             DateTime            @default(now())
  // Relations
  user                  User                @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([emiScheduleId])
  @@index([offlineLoanEMIId])
  @@index([sentAt])
  @@index([reminderType])
}

// Offline Loan Status Enum
enum OfflineLoanStatus {
  ACTIVE
  CLOSED
  DEFAULTED
  RESTRUCTURED
}

// Action Log - For undo/redo functionality
model ActionLog {
  id                    String              @id @default(cuid())
  // Who performed the action
  userId                String
  userRole              String
  // Action details
  actionType            String              // CREATE, UPDATE, DELETE, PAYMENT, etc.
  module                String              // OFFLINE_LOAN, EMI_PAYMENT, SETTLEMENT, etc.
  recordId              String              // ID of the affected record
  recordType            String              // OfflineLoan, OfflineLoanEMI, Payment, etc.
  // Data snapshots
  previousData          String?             // JSON string of data before action
  newData               String?             // JSON string of data after action
  // Undo tracking
  canUndo               Boolean             @default(true)
  isUndone              Boolean             @default(false)
  undoneAt              DateTime?
  undoneById            String?
  // Redo tracking
  canRedo               Boolean             @default(false)
  isRedone              Boolean             @default(false)
  redoneAt              DateTime?
  redoneById            String?
  // Metadata
  description           String
  ipAddress             String?
  userAgent             String?
  // Timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  // Relations
  user                  User                @relation(fields: [userId], references: [id])
  undoneBy              User?               @relation("ActionUndoBy", fields: [undoneById], references: [id])
  redoneBy              User?               @relation("ActionRedoBy", fields: [redoneById], references: [id])
  @@index([userId])
  @@index([actionType])
  @@index([module])
  @@index([recordId])
}

// ==================== FIXED ASSETS MANAGEMENT ====================

// Fixed Asset - Track company's fixed assets with depreciation
model FixedAsset {
  id                    String              @id @default(cuid())
  companyId             String              @default("default")
  
  // Asset Identification
  assetCode             String              // Unique asset code (e.g., FA-001)
  assetName             String              // Name of the asset
  assetCategory         AssetCategory       // Category of the asset
  
  // Asset Details
  description           String?             // Detailed description
  serialNumber          String?             // Serial number for equipment
  location              String?             // Physical location of asset
  department            String?             // Department using the asset
  
  // Financial Details
  purchaseDate          DateTime            // Date of purchase
  purchaseCost          Float               // Original purchase cost
  additionalCosts       Float               @default(0) // Installation, transport, etc.
  totalCost             Float               // purchaseCost + additionalCosts
  salvageValue          Float               @default(0) // Expected salvage/residual value
  usefulLifeYears       Int                 // Estimated useful life in years
  usefulLifeMonths      Int                 // Useful life in months
  
  // Depreciation Details
  depreciationMethod    DepreciationMethod  @default(STRAIGHT_LINE)
  depreciationRate      Float               @default(0) // Annual depreciation rate (%)
  accumulatedDepreciation Float             @default(0) // Total depreciation till date
  currentBookValue      Float               @default(0) // Current book value after depreciation
  lastDepreciationDate  DateTime?           // Last depreciation calculated date
  
  // Status & Lifecycle
  status                AssetStatus         @default(ACTIVE)
  acquisitionDate       DateTime?           // Date when asset was acquired
  disposalDate          DateTime?           // Date when asset was disposed
  disposalValue         Float?              // Value received on disposal
  disposalReason        String?             // Reason for disposal
  
  // Insurance & Warranty
  insuranceProvider     String?
  insurancePolicyNo     String?
  insuranceExpiryDate   DateTime?
  warrantyProvider      String?
  warrantyExpiryDate    DateTime?
  
  // Maintenance
  lastMaintenanceDate   DateTime?
  nextMaintenanceDate   DateTime?
  maintenanceNotes      String?
  
  // Documentation
  invoiceNumber         String?
  invoiceDate           DateTime?
  invoiceUrl            String?             // URL to invoice document
  imageUrl              String?             // Photo of the asset
  
  // Audit Trail
  createdById           String
  approvedById          String?
  approvedAt            DateTime?
  
  // Timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  // Relations
  company               Company?            @relation(fields: [companyId], references: [id])
  depreciationLogs      AssetDepreciationLog[]
  
  @@unique([companyId, assetCode])
  @@index([companyId])
  @@index([assetCode])
  @@index([assetCategory])
  @@index([status])
  @@index([purchaseDate])
}

// Asset Depreciation Log - Track monthly/yearly depreciation entries
model AssetDepreciationLog {
  id                    String              @id @default(cuid())
  assetId               String
  
  // Depreciation Period
  depreciationDate      DateTime            // Date of depreciation calculation
  financialYear         String              // e.g., "2024-25"
  period                String              // e.g., "March 2024"
  
  // Amounts
  openingBookValue      Float               // Book value at start of period
  depreciationAmount    Float               // Depreciation for this period
  closingBookValue      Float               // Book value after depreciation
  
  // Journal Reference
  journalEntryId        String?             // Link to journal entry if created
  
  // Metadata
  calculatedAt          DateTime            @default(now())
  calculatedById        String
  
  // Relation
  asset                 FixedAsset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  @@index([assetId])
  @@index([depreciationDate])
  @@index([financialYear])
}

// Asset Category Enum
enum AssetCategory {
  FURNITURE_FIXTURES       // Tables, chairs, cabinets
  OFFICE_EQUIPMENT         // Computers, printers, scanners
  VEHICLES                 // Cars, bikes, trucks
  MACHINERY_PLANT          // Manufacturing equipment
  BUILDINGS                // Office buildings, warehouses
  LAND                     // Land assets
  ELECTRONICS              // Laptops, phones, tablets
  ELECTRICAL_INSTALLATIONS // ACs, generators, electrical fittings
  INTANGIBLE_ASSETS        // Software licenses, patents
  OTHER                    // Any other fixed assets
}

// Depreciation Method Enum
enum DepreciationMethod {
  STRAIGHT_LINE            // Equal depreciation each year
  DIMINISHING_BALANCE      // Reducing balance method
  WRITTEN_DOWN_VALUE       // WDV method (common in India)
  UNITS_OF_PRODUCTION      // Based on usage
}

// Asset Status Enum
enum AssetStatus {
  ACTIVE                   // Currently in use
  UNDER_MAINTENANCE        // Being repaired/maintained
  DISPOSED                 // Sold or scrapped
  WRITTEN_OFF              // Fully depreciated or lost
  SOLD                     // Sold to another party
  IDLE                     // Not in use but not disposed
}

// ==================== PAYMENT REQUEST SYSTEM ====================

// Payment Request - Customer initiated payment requests
model PaymentRequest {
  id                    String              @id @default(cuid())
  requestNumber         String              @unique
  
  // Loan & EMI Details
  loanApplicationId     String
  emiScheduleId         String?
  customerId            String
  
  // Payment Details
  paymentType           PaymentType         @default(FULL_EMI)
  requestedAmount       Float
  
  // For Partial Payment
  partialAmount         Float?              // Amount being paid now
  remainingAmount       Float?              // Remaining amount to pay later
  newDueDate            DateTime?           // New due date for remaining amount
  partialPaymentNumber  Int?                @default(0)  // 1st or 2nd partial payment
  
  // For Interest Only Payment
  interestAmount        Float?              // Interest amount being paid
  principalDeferred     Boolean             @default(false)
  
  // Payment Method Details
  paymentMethod         String?             // UPI, BANK_TRANSFER, CASH
  utrNumber             String?
  proofUrl              String?             // Screenshot proof
  proofFileName         String?
  
  // QR/UPI Payment Details
  upiId                 String?
  qrCodeUrl             String?
  bankAccountDetails    String?             // JSON string with bank details
  
  // Status & Approval
  status                PaymentRequestStatus @default(PENDING)
  
  // Approval Details
  reviewedById          String?
  reviewedAt            DateTime?
  reviewRemarks         String?
  rejectionReason       String?
  
  // Payment Confirmation
  paymentConfirmedAt    DateTime?
  transactionRef        String?
  
  // Timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  // Relations
  loanApplication       LoanApplication     @relation(fields: [loanApplicationId], references: [id])
  emiSchedule           EMISchedule?        @relation(fields: [emiScheduleId], references: [id])
  customer              User                @relation(fields: [customerId], references: [id])
  reviewer              User?               @relation("PaymentRequestReviewer", fields: [reviewedById], references: [id])
  
  @@index([loanApplicationId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

enum PaymentRequestStatus {
  PENDING                // Waiting for cashier review
  UNDER_REVIEW           // Being reviewed by cashier
  APPROVED               // Approved by cashier, EMI marked paid
  REJECTED               // Rejected by cashier
  EXPIRED                // Request expired (e.g., time limit passed)
  CANCELLED              // Cancelled by customer
}

// Payment Option Settings - Role-based settings for payment options
model PaymentOptionSettings {
  id                    String              @id @default(cuid())
  
  // Scope - can be global, company-specific, or loan-specific
  scope                 String              @default("GLOBAL")  // GLOBAL, COMPANY, LOAN
  companyId             String?
  loanApplicationId     String?
  
  // Payment Options Enabled
  enableFullPayment     Boolean             @default(true)
  enablePartialPayment  Boolean             @default(true)
  enableInterestOnly    Boolean             @default(true)
  
  // Partial Payment Settings
  maxPartialPayments    Int                 @default(2)        // Max 2 partial payments per EMI
  partialPaymentFee     Float               @default(0)
  
  // Interest Only Settings
  maxInterestOnlyPerLoan Int                @default(3)        // Max 3 interest-only payments per loan
  interestOnlyFee       Float               @default(0)
  
  // Payment Method Settings
  acceptedPaymentMethods String             @default("UPI,BANK_TRANSFER,CASH")
  
  // UPI/QR Settings
  defaultUpiId          String?
  defaultQrCodeUrl      String?
  defaultBankDetails    String?             // JSON string with bank details
  
  // Created/Updated by
  createdById           String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  @@index([scope])
  @@index([companyId])
  @@index([loanApplicationId])
}

// Company Payment Settings - Company-specific payment configurations
model CompanyPaymentSettings {
  id                    String              @id @default(cuid())
  companyId             String              @unique
  
  // Payment Options
  enableFullPayment     Boolean             @default(true)
  enablePartialPayment  Boolean             @default(true)
  enableInterestOnly    Boolean             @default(true)
  
  // Partial Payment Rules
  maxPartialPaymentsPerEMI  Int             @default(2)
  partialPaymentFeePercent  Float           @default(0)
  allowDateChangeOnPartial  Boolean         @default(true)
  
  // Interest Only Rules
  maxInterestOnlyPayments   Int             @default(3)
  interestOnlyFeePercent    Float           @default(0)
  addNewEMIOnInterestOnly   Boolean         @default(true)  // Add new EMI with principal + interest
  
  // Payment Methods
  acceptedMethods        String             @default("UPI,BANK_TRANSFER,CASH")
  
  // UPI Configuration
  companyUpiId          String?
  companyQrCodeUrl      String?
  
  // Bank Account for Collections
  collectionBankAccountId String?
  
  // Created/Updated
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  
  company               Company?            @relation(fields: [companyId], references: [id])
}

// Secondary Payment Pages (Display Only - Created by Cashier)
// These are for showing different payment details to customers
// BUT actual transactions happen in Company's Default Bank Account
model SecondaryPaymentPage {
  id                    String   @id @default(cuid())
  companyId             String   // Which company this payment page belongs to
  name                  String   // Name for this payment page (e.g., "Partner Collection Point 1")
  description           String? // Description
  
  // Payment Display Details (what customer sees)
  upiId                 String?   // UPI ID shown to customer
  qrCodeUrl             String?   // QR Code image shown to customer
  bankName              String?   // Bank name shown to customer
  accountNumber         String?   // Account number shown to customer
  accountName           String?   // Account holder name shown to customer
  ifscCode              String?   // IFSC code shown to customer
  
  isActive              Boolean  @default(true)
  createdById           String   // Who created this payment page (usually Cashier)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  company               Company? @relation(fields: [companyId], references: [id])
  creator               User?    @relation(fields: [createdById], references: [id])
  emiPaymentSettings    EMIPaymentSetting[]
  
  @@index([companyId])
  @@index([isActive])
}

// EMI Payment Settings - Per EMI toggle options
model EMIPaymentSetting {
  id                      String   @id @default(cuid())
  emiScheduleId            String   @unique
  loanApplicationId       String
  
  // Payment Options Toggle
  enableFullPayment       Boolean  @default(true)
  enablePartialPayment    Boolean  @default(true)
  enableInterestOnly      Boolean  @default(true)
  
  // Payment Page Selection (which payment details to show to customer)
  useDefaultCompanyPage   Boolean  @default(true)  // true = use company's default bank account
  secondaryPaymentPageId  String?   // If useDefaultCompanyPage is false, use this secondary page
  
  // Tracking
  lastModifiedById        String?   // Who last modified these settings
  lastModifiedAt          DateTime? @updatedAt
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  emiSchedule             EMISchedule?        @relation(fields: [emiScheduleId], references: [id])
  loanApplication         LoanApplication?   @relation(fields: [loanApplicationId], references: [id])
  secondaryPaymentPage    SecondaryPaymentPage? @relation(fields: [secondaryPaymentPageId], references: [id])
  modifiedBy              User?               @relation(fields: [lastModifiedById], references: [id])
  
  @@index([emiScheduleId])
  @@index([loanApplicationId])
}
