  currencySymbol        String   @default("₹")
  decimalPlaces         Int      @default(2)
  enableGST             Boolean  @default(false)
  gstNumber             String?
  gstRate               Float    @default(18)
  enableTDS             Boolean  @default(false)
  tdsRate               Float    @default(10)
  fiscalYearPrefix      String   @default("FY")
  journalEntryPrefix    String   @default("JE")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Company Accounting Settings Extension
model CompanyAccountingSettings {
  id                        String   @id @default(cuid())
  companyId                 String   @unique
  defaultBankAccountId      String?
  autoJournalEntries        Boolean  @default(true)
  requireApproval           Boolean  @default(false)
